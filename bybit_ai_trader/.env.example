# =============================================================================
# Bybit AI Trader - Environment Configuration (ADVANCED)
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Bybit API Credentials
# -----------------------------------------------------------------------------
# Get these from: https://testnet.bybit.com/app/api-keys (for testing)
# Or: https://www.bybit.com/app/api-keys (for live trading)
BYBIT_API_KEY=YOUR_BYBIT_API_KEY_HERE
BYBIT_SECRET_KEY=YOUR_BYBIT_SECRET_KEY_HERE

# API Environment: testnet or mainnet
BYBIT_ENV=testnet

# -----------------------------------------------------------------------------
# Trading Mode
# -----------------------------------------------------------------------------
# paper = Simulated trading with live data (recommended for testing)
# live = Real money trading (use with caution!)
TRADING_MODE=paper

# Enable/disable trading
TRADING_ENABLED=true

# -----------------------------------------------------------------------------
# Advanced Risk Management Settings (LOW RISK CONFIGURATION)
# -----------------------------------------------------------------------------
# Conservative risk per trade using Kelly Criterion (0.25-0.5 recommended for crypto)
# This is the maximum risk; actual risk is dynamically calculated
RISK_PER_TRADE=0.25

# Maximum leverage allowed (1-100)
# Recommendation: 3-5x for low-risk, max 10x for experienced traders
MAX_LEVERAGE=5

# Loss limits (percentage of account) - CONSERVATIVE SETTINGS
DAILY_LOSS_LIMIT=2.0      # Stop trading after 2% daily loss
WEEKLY_LOSS_LIMIT=5.0     # Stop trading after 5% weekly loss
MONTHLY_LOSS_LIMIT=10.0   # Stop trading after 10% monthly loss

# Maximum number of simultaneous positions (diversification limit)
MAX_POSITIONS=3

# Minimum risk/reward ratio for entries (1:3 means target is 3x the risk)
MIN_RISK_REWARD=3.0

# Kelly Criterion multiplier (0.0-1.0)
# 0.5 = Half Kelly (conservative), 1.0 = Full Kelly (aggressive)
KELLY_MULTIPLIER=0.5

# Maximum portfolio exposure (total position value / account balance)
MAX_PORTFOLIO_EXPOSURE=1.5

# Correlation threshold (avoid highly correlated positions)
MAX_CORRELATION=0.7

# Value at Risk (VaR) confidence level (0.95 = 95%)
VAR_CONFIDENCE_LEVEL=0.95

# Maximum VaR limit (percentage of portfolio)
MAX_VAR_LIMIT=3.0

# -----------------------------------------------------------------------------
# Advanced Execution Settings (SCALE-IN/SCALE-OUT)
# -----------------------------------------------------------------------------
# Enable scale-in entries (multiple tranches)
SCALE_IN_ENABLED=true

# Number of scale-in tranches
SCALE_IN_TRANCHES=3

# Scale-in price increments (percentage)
SCALE_IN_INCREMENT=0.5

# Enable scale-out exits (partial profits)
SCALE_OUT_ENABLED=true

# Number of scale-out levels
SCALE_OUT_LEVELS=3

# Scale-out percentages at each level (comma-separated)
SCALE_OUT_PERCENTAGES=30,30,40

# Scale-out profit targets (percentage from entry, comma-separated)
SCALE_OUT_TARGETS=1.0,2.0,3.0

# Trailing stop activation (percentage profit)
TRAILING_STOP_ACTIVATION=1.5

# Trailing stop distance (percentage)
TRAILING_STOP_DISTANCE=0.5

# -----------------------------------------------------------------------------
# Advanced Stop-Loss Strategies
# -----------------------------------------------------------------------------
# Use ATR-based stop loss
ATR_STOP_ENABLED=true

# ATR multiplier for stop loss
ATR_STOP_MULTIPLIER=2.5

# Use Chandelier Exit for trailing stops
CHANDELIER_EXIT_ENABLED=true

# Chandelier Exit period
CHANDELIER_PERIOD=22

# Chandelier Exit multiplier
CHANDELIER_MULTIPLIER=3.0

# Use volatility-adjusted stops
VOLATILITY_STOP_ENABLED=true

# -----------------------------------------------------------------------------
# Multi-Strategy System
# -----------------------------------------------------------------------------
# Enable multiple strategies
STRATEGY_ENSEMBLE_ENABLED=true

# Strategy weights (comma-separated, must sum to 1.0)
# Order: trend_following, mean_reversion, breakout, momentum
STRATEGY_WEIGHTS=0.4,0.3,0.2,0.1

# Minimum confluence score for entry (0-100)
MIN_CONFLUENCE_SCORE=75

# Enable multi-timeframe analysis
MULTI_TIMEFRAME_ENABLED=true

# Timeframes for confluence (comma-separated)
CONFLUENCE_TIMEFRAMES=5m,15m,1h

# -----------------------------------------------------------------------------
# Market Scanner Settings
# -----------------------------------------------------------------------------
# Enable/disable market scanner
SCANNER_ENABLED=true

# How often to scan markets (in seconds)
SCAN_INTERVAL=5

# Minimum opportunity score to consider (0-100)
OPPORTUNITY_THRESHOLD=85

# Focus on top volume symbols
TOP_VOLUME_SYMBOLS=20

# Minimum 24h volume (in USDT)
MIN_24H_VOLUME=1000000

# Trading hours filter (avoid low liquidity periods)
TRADING_HOURS_START=0
TRADING_HOURS_END=24

# Avoid trading during major news events
NEWS_FILTER_ENABLED=true

# -----------------------------------------------------------------------------
# Funding Rate Arbitrage
# -----------------------------------------------------------------------------
# Enable funding rate monitoring
FUNDING_RATE_ENABLED=true

# Minimum funding rate to consider (percentage)
MIN_FUNDING_RATE=0.01

# Maximum funding rate exposure time (hours)
MAX_FUNDING_EXPOSURE=8

# -----------------------------------------------------------------------------
# Dashboard Settings
# -----------------------------------------------------------------------------
# Dashboard refresh rate in seconds
DASHBOARD_REFRESH_RATE=1.0

# Show all symbols or only top opportunities
SHOW_ALL_SYMBOLS=false

# Number of top opportunities to display
TOP_OPPORTUNITIES=10

# Show advanced risk metrics
SHOW_RISK_METRICS=true

# -----------------------------------------------------------------------------
# Logging Settings
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable file logging
LOG_TO_FILE=true

# -----------------------------------------------------------------------------
# Telegram Bot Integration (Optional)
# -----------------------------------------------------------------------------
# Get bot token from @BotFather on Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Send alerts for risk events
TELEGRAM_RISK_ALERTS=true

# Send trade confirmations
TELEGRAM_TRADE_ALERTS=true

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# SQLite database file path
DATABASE_PATH=database/trading.db

# Enable trade history archival
ARCHIVE_TRADES=true

# -----------------------------------------------------------------------------
# Cache Settings
# -----------------------------------------------------------------------------
# Enable local caching of market data
CACHE_ENABLED=true
CACHE_TTL=300  # Cache time-to-live in seconds

# -----------------------------------------------------------------------------
# Machine Learning / AI Settings (Optional)
# -----------------------------------------------------------------------------
# Enable ML predictions
ML_ENABLED=false

# Model type: lstm, xgboost, random_forest, ensemble
ML_MODEL_TYPE=ensemble

# Retrain model frequency (hours)
ML_RETRAIN_FREQUENCY=24

# Prediction confidence threshold (0.0-1.0)
ML_CONFIDENCE_THRESHOLD=0.65

# Feature lookback period (candles)
FEATURE_LOOKBACK=100

# Enable sentiment analysis
SENTIMENT_ANALYSIS_ENABLED=false

# -----------------------------------------------------------------------------
# Backtesting & Optimization Settings
# -----------------------------------------------------------------------------
# Default backtest start date (YYYY-MM-DD)
BACKTEST_START_DATE=2024-01-01

# Default backtest end date (YYYY-MM-DD)
BACKTEST_END_DATE=2024-12-31

# Initial capital for backtesting
BACKTEST_INITIAL_CAPITAL=10000

# Enable walk-forward optimization
WALK_FORWARD_ENABLED=true

# Walk-forward training window (days)
WF_TRAIN_WINDOW=90

# Walk-forward testing window (days)
WF_TEST_WINDOW=30

# Optimization method: bayesian, grid, random
OPTIMIZATION_METHOD=bayesian

# Max optimization iterations
MAX_OPTIMIZATION_ITERATIONS=100

# -----------------------------------------------------------------------------
# Safety Features & Circuit Breakers
# -----------------------------------------------------------------------------
# Enable kill switch (set to true to immediately stop all trading)
KILL_SWITCH=false

# Enable circuit breaker (stops trading after consecutive losses)
CIRCUIT_BREAKER_ENABLED=true

# Number of consecutive losses before circuit breaker triggers
CIRCUIT_BREAKER_THRESHOLD=3

# Cooldown period after circuit breaker triggers (in minutes)
CIRCUIT_BREAKER_COOLDOWN=120

# Enable drawdown circuit breaker
DRAWDOWN_CIRCUIT_BREAKER=true

# Maximum drawdown before halt (percentage)
MAX_DRAWDOWN=5.0

# Enable slippage protection
SLIPPAGE_PROTECTION=true

# Maximum acceptable slippage (percentage)
MAX_SLIPPAGE=0.1

# Enable price impact protection
PRICE_IMPACT_PROTECTION=true

# Maximum price impact (percentage)
MAX_PRICE_IMPACT=0.05

# -----------------------------------------------------------------------------
# Advanced Performance Settings
# -----------------------------------------------------------------------------
# Maximum CPU usage percentage (for throttling)
MAX_CPU_PERCENT=70

# Maximum memory usage in MB (for throttling)
MAX_MEMORY_MB=400

# API request timeout in seconds
API_TIMEOUT=30

# Maximum retry attempts for failed API requests
MAX_RETRIES=3

# Delay between retries in seconds
RETRY_DELAY=1.0

# Enable WebSocket reconnection
WS_RECONNECT=true

# WebSocket ping interval in seconds
WS_PING_INTERVAL=20

# Rate limiting (requests per second)
RATE_LIMIT=10

# -----------------------------------------------------------------------------
# Position Sizing Advanced Settings
# -----------------------------------------------------------------------------
# Use dynamic position sizing based on volatility
DYNAMIC_SIZING_ENABLED=true

# Volatility measurement: atr, std_dev, historical
VOLATILITY_METHOD=atr

# Target volatility (annualized percentage)
TARGET_VOLATILITY=15.0

# Minimum position size (USDT)
MIN_POSITION_SIZE=10

# Maximum position size (USDT)
MAX_POSITION_SIZE=5000

# -----------------------------------------------------------------------------
# Advanced Analytics
# -----------------------------------------------------------------------------
# Enable Sharpe ratio calculation
SHARPE_RATIO_ENABLED=true

# Enable Sortino ratio calculation
SORTINO_RATIO_ENABLED=true

# Enable maximum drawdown tracking
MAX_DD_TRACKING=true

# Enable win rate tracking
WIN_RATE_TRACKING=true

# Enable profit factor calculation
PROFIT_FACTOR_TRACKING=true

# Risk-free rate for Sharpe/Sortino (annualized, decimal)
RISK_FREE_RATE=0.05
